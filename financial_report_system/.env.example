# ===========================================
# 信贷风险分析系统 - 环境配置示例
# ===========================================
# 复制此文件为 .env 并填写实际值
# 或直接使用下面的默认值运行

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info

# 应用配置
APP_VERSION=2.1.2
CACHE_ENABLED=true

# 任务配置
TASK_TIMEOUT=300
MAX_FILE_SIZE=50
MAX_FILES=20

# 报告配置
PDF_ENABLED=true
REPORT_TTL=24

# M-Score 配置
MSCORE_SAFE=-2.22
MSCORE_WARN=-1.78
